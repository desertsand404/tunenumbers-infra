apiVersion: v1
kind: Secret
metadata:
  name: umami-secret
  namespace: tunenumbers
type: Opaque
data:
  # Password is URL-encoded: umami 3.x parses DATABASE_URL with new URL(), which
  # rejects raw base64 passwords containing '/', '=' or '+'. The pg driver decodes
  # the percent-escapes back to the real password.
  DATABASE_URL: {{ ("postgresql://umami:" + (umami_db_password | urlencode) + "@postgresql:5432/umami") | b64encode }}
  APP_SECRET: {{ umami_app_secret | b64encode }}
