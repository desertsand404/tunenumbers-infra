{
  "annotations": { "list": [] },
  "description": "CrowdSec brute-force protection: active bans, banned IPs, login failures, and unblock history",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 1 },
            { "color": "red", "value": 5 }
          ]},
          "unit": "short",
          "mappings": [{ "options": { "0": { "text": "None" } }, "type": "value" }]
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Active Bans",
      "type": "stat",
      "targets": [{ "expr": "sum(cs_active_decisions{action=\"ban\"})", "legendFormat": "banned IPs", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "displayName", "value": "Count" }] }
        ]
      },
      "gridPos": { "h": 5, "w": 18, "x": 6, "y": 0 },
      "id": 2,
      "options": { "showHeader": true, "sortBy": [{ "desc": true, "displayName": "Count" }] },
      "title": "Active Bans by Scenario",
      "type": "table",
      "targets": [{ "expr": "cs_active_decisions{action=\"ban\"}", "legendFormat": "", "refId": "A", "instant": true, "format": "table" }],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "__name__": true, "job": true, "instance": true }, "renameByName": { "reason": "Scenario", "origin": "Origin" } } }
      ]
    },
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "crowdsec-lapi" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 5 },
      "id": 30,
      "options": { "showHeader": true, "sortBy": [{ "desc": true, "displayName": "Scenario" }], "footer": { "show": true, "countRows": true, "reducer": ["count"] } },
      "title": "Banned IPs (CrowdSec Decisions)",
      "type": "table",
      "targets": [{
        "refId": "A",
        "type": "json",
        "source": "url",
        "format": "table",
        "url": "http://crowdsec-service.crowdsec.svc.cluster.local:8080/v1/decisions",
        "url_options": {
          "method": "GET",
          "headers": [
            { "key": "X-Api-Key", "value": "REDACTED" }
          ]
        },
        "root_selector": "",
        "columns": [
          { "selector": "value", "text": "IP", "type": "string" },
          { "selector": "scenario", "text": "Scenario", "type": "string" },
          { "selector": "origin", "text": "Origin", "type": "string" },
          { "selector": "duration", "text": "Duration", "type": "string" },
          { "selector": "type", "text": "Action", "type": "string" }
        ]
      }]
    },
    {
      "datasource": { "type": "loki", "uid": "${lokids}" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 10,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Login Failures per Minute",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(count_over_time({namespace=\"tunenumbers\", pod=~\"directus.*\"} |= \"/auth/login\" |= \"401\" [1m]))",
          "legendFormat": "Directus",
          "refId": "A"
        },
        {
          "expr": "sum(count_over_time({namespace=\"monitoring\", pod=~\"grafana.*\"} |~ \"(?i)invalid username or password\" [1m]))",
          "legendFormat": "Grafana",
          "refId": "B"
        },
        {
          "expr": "sum(count_over_time({namespace=\"gitea\"} |~ \"(?i)failed authentication|failed to authenticate\" [1m]))",
          "legendFormat": "Gitea",
          "refId": "C"
        },
        {
          "expr": "sum(count_over_time({namespace=\"kube-system\", pod=~\"traefik.*\"} |= \"/api/v1/login\" |= \"401\" [1m]))",
          "legendFormat": "MinIO",
          "refId": "D"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 11,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Active Bans Over Time",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(cs_active_decisions{action=\"ban\"})", "legendFormat": "Total Bans", "refId": "A" },
        { "expr": "cs_active_decisions{action=\"ban\"}", "legendFormat": "{{reason}}", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${lokids}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 23 },
      "id": 20,
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "showLabels": false, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": false },
      "title": "Unblock History (flushed alerts)",
      "type": "logs",
      "targets": [{ "expr": "{namespace=\"crowdsec\", container=\"crowdsec-lapi\"} |= \"flushed\" |= \"alerts\" | logfmt", "refId": "A" }]
    },
    {
      "datasource": { "type": "loki", "uid": "${lokids}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 31 },
      "id": 21,
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "showLabels": false, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": false },
      "title": "CrowdSec Ban Events",
      "type": "logs",
      "targets": [{ "expr": "{namespace=\"crowdsec\", container=\"crowdsec-lapi\"} |~ \"community-blocklist update|POST /v1/alerts\" | logfmt", "refId": "A" }]
    },
    {
      "datasource": { "type": "loki", "uid": "${lokids}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 39 },
      "id": 22,
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "showLabels": false, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": false },
      "title": "MinIO Login Failures (via Traefik)",
      "type": "logs",
      "targets": [{ "expr": "{namespace=\"kube-system\", pod=~\"traefik.*\"} |= \"/api/v1/login\" |= \"401\"", "refId": "A" }]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["security", "crowdsec", "brute-force"],
  "templating": {
    "list": [
      { "current": {}, "hide": 0, "includeAll": false, "name": "datasource", "options": [], "query": "prometheus", "refresh": 1, "type": "datasource", "label": "Prometheus" },
      { "current": {}, "hide": 0, "includeAll": false, "name": "lokids", "options": [], "query": "loki", "refresh": 1, "type": "datasource", "label": "Loki" }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Security Overview",
  "uid": "tunenumbers-security",
  "version": 1
}
