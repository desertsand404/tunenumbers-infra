---
# Copy this file to secrets.yml and fill in real values.
# Encrypt with: ansible-vault encrypt ansible/vars/secrets.yml
# NEVER commit secrets.yml unencrypted.

# Let's Encrypt registration email
vault_letsencrypt_email: admin@tunenumbers.de

# PostgreSQL
pg_password: CHANGE_ME_pg_password

# MinIO (S3-compatible object storage)
minio_root_user: minioadmin
minio_root_password: CHANGE_ME_minio_password

# Directus (headless CMS)
directus_admin_email: admin@tunenumbers.de
directus_admin_password: CHANGE_ME_directus_password
directus_secret: CHANGE_ME_random_64_char_string

# Gitea (self-hosted Git)
gitea_admin_user: tuneadmin
gitea_admin_password: CHANGE_ME_gitea_password
gitea_admin_email: admin@tunenumbers.de
