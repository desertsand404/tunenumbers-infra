---
# Kopiere nach secrets.yml und setze echte Werte.
# secrets.yml wird NICHT committed (.gitignore).
# In GitHub Actions werden diese aus GitHub Secrets generiert.
letsencrypt_email: "your-email@example.com"
pg_password: "CHANGE_ME"
pg_exporter_password: "CHANGE_ME"
minio_root_user: "CHANGE_ME"
minio_root_password: "CHANGE_ME"
directus_admin_email: "admin@example.com"
directus_admin_password: "CHANGE_ME"
directus_secret: "CHANGE_ME_LONG_RANDOM_STRING"
gitea_admin_user: "CHANGE_ME"
gitea_admin_password: "CHANGE_ME"
gitea_admin_email: "admin@example.com"

# ── Umami Analytics ──────────────────────────────────────────────────────────
umami_db_password: "CHANGE_ME"
umami_app_secret: "CHANGE_ME_LONG_RANDOM_STRING"

# ── Backup (restic) ──────────────────────────────────────────────────────────
# Hetzner Storage Box (SFTP) example:
#   backup_restic_repository: "sftp:u123456@u123456.your-storagebox.de:/tunenumbers"
# Hetzner Object Storage (S3) example:
#   backup_restic_repository: "s3:https://fsn1.your-objectstorage.com/my-bucket"
backup_restic_repository: "CHANGE_ME"
backup_restic_password: "CHANGE_ME_STRONG_RANDOM_PASSWORD"
# Optional extra environment variables for the restic backend (e.g. S3 keys).
# Leave empty string if not needed. Multiline supported.
backup_restic_env_extra: ""
# Example for S3:
# backup_restic_env_extra: |
#   AWS_ACCESS_KEY_ID="your-access-key"
#   AWS_SECRET_ACCESS_KEY="your-secret-key"
